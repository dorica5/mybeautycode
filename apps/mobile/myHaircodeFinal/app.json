{
  "expo": {
    "name": "myHaircode",
    "slug": "myHaircodeFinal",
    "newArchEnabled": true,
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/appstore.png",
    "scheme": "myhaircode",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#B2DCC5"
    },
    "ios": {
      "supportsTablet": true,
      "requireFullScreen": true,
      "bundleIdentifier": "com.dorica.myHaircodeFinal1",
      "infoPlist": {
        "UISupportedInterfaceOrientations": ["UIInterfaceOrientationPortrait"],
        "UISupportedInterfaceOrientations~ipad": [
          "UIInterfaceOrientationPortrait"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["remote-notification"],
        "NSCameraUsageDescription": "myHaircode uses the camera to take photos of your hair and inspiration images for your hair journal.",
        "NSPhotoLibraryUsageDescription": "myHaircode needs access to your photo library so you can choose and upload hair inspiration and profile photos.",
        "NSPhotoLibraryAddUsageDescription": "myHaircode saves edited or captured photos to your library when you choose to."
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "screenOrientation": "portrait",
      "adaptiveIcon": {
        "foregroundImage": "./assets/appstore.png",
        "backgroundColor": "#ffffff"
      },
      "versionCode": 1,
      "package": "com.dorica.myHaircodeFinal",
      "googleServicesFile": "./google-services.json",
      "permissions": ["NOTIFICATIONS"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-screen-orientation",
        { "initialOrientation": "PORTRAIT" }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "myHaircode needs your location to show nearby salons on the map."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/appstore.png",
          "color": "#ffffff"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          },
          "android": {
            "kotlinVersion": "2.0.21"
          }
        }
      ],
      "./plugins/removeEnableBundleCompression",
      "./plugins/withAndroidPortraitOnly"
    ],

    "experiments": {
      "typedRoutes": true
    },
    "assetBundlePatterns": ["**/*"],
    "extra": {
      "SUPABASE_URL": "${SUPABASE_URL}",
      "SUPABASE_FUNCTION_URL": "${SUPABASE_FUNCTION_URL}",
      "SUPABASE_ANON": "${SUPABASE_ANON}",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "88667b8c-f786-4a66-aa68-d9b4ee0c7c8e"
      }
    },
    "owner": "dorica"
  }
}
