{
  "cli": {
    "version": ">= 14.2.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "credentialsSource": "remote" },
      "android": {
        "credentialsSource": "remote",
        "gradleCommand": ":app:assembleDebug",
        "buildType": "apk"
      },
      "env": {
        "NPM_USE_CI": "false",
        "EXPO_PUBLIC_DEV_PASSWORD_RESET": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": { "credentialsSource": "remote" },
      "android": {
        "credentialsSource": "remote",
        "gradleCommand": ":app:assembleRelease",
        "buildType": "apk"
      },
      "env": {
        "NPM_USE_CI": "false",
        "EXPO_PUBLIC_DEV_PASSWORD_RESET": "true",
        "EXPO_NO_DEV_CLIENT": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": { "credentialsSource": "remote" },
      "android": {
        "credentialsSource": "remote",
        "buildType": "app-bundle"
      },
      "env": {
        "NPM_USE_CI": "false",
        "EXPO_NO_DEV_CLIENT": "1"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "production"
      }
    }
  }
}
