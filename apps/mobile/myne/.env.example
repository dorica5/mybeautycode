# Mobile app — environment template
# Copy to `.env` and fill in values. Never commit `.env`.

# --- Supabase (required) ---
SUPABASE_PROJECTID=your-project-ref
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_FUNCTION_URL=https://your-project-ref.functions.supabase.co
SUPABASE_ANON=your-anon-key

# --- Backend API (required for EAS builds — must be reachable from phones) ---
# Local dev only:
# EXPO_PUBLIC_API_URL=http://192.168.x.x:3001
# Production / review builds:
EXPO_PUBLIC_API_URL=https://your-api.example.com

# Metro QR on physical device (local dev only)
# REACT_NATIVE_PACKAGER_HOSTNAME=192.168.x.x

# --- Google Maps / Places (optional but needed for map + address autocomplete) ---
# EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=
# EXPO_PUBLIC_GOOGLE_MAPS_IOS_KEY=
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=

# --- RevenueCat (required for subscription testing on device builds) ---
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_xxx
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_xxx

# --- Billing display defaults ---
EXPO_PUBLIC_BILLING_FREE_VISIT_LIMIT=10
EXPO_PUBLIC_BILLING_MONTHLY_PRICE_NOK=99
EXPO_PUBLIC_BILLING_ANNUAL_PRICE_NOK=990

# --- Dev / QA flags ---
# Skip paywall after pro onboarding save (local QA only)
EXPO_PUBLIC_BYPASS_PRO_PAYWALL=false
# Show paste-recovery-link UI on preview/internal builds (forgot-password testing)
EXPO_PUBLIC_DEV_PASSWORD_RESET=true
# Dev only: reload app to preview first-run onboarding
# EXPO_PUBLIC_PREVIEW_ONBOARDING=true

# --- Legal URLs (paywall links; defaults to https://myne.no/terms and /privacy) ---
# EXPO_PUBLIC_SITE_URL=https://myne.no
# EXPO_PUBLIC_TERMS_URL=
# EXPO_PUBLIC_PRIVACY_URL=
