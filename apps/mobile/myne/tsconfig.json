{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": "",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@components/*" : ["src/components/*"],
      "@constants/*" : ["src/constants/*"],
      "@assets/*" : ["assets/*"],
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
, "src/components/DraggableModal.tsx", "src/app/(client)/(tabs)/notifications/notificationsDataClient.js", "src/app/reset-password.tsx"  ]
}