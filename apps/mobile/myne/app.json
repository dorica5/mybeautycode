{
  "expo": {
    "name": "myne",
    "slug": "mybeautycode",
    "newArchEnabled": true,
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/appstore.png",
    "scheme": "myne",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#B2DCC5"
    },
    "ios": {
      "supportsTablet": true,
      "requireFullScreen": true,
      "bundleIdentifier": "com.dorica.myne",
      "infoPlist": {
        "UISupportedInterfaceOrientations": [
          "UIInterfaceOrientationPortrait"
        ],
        "UISupportedInterfaceOrientations~ipad": [
          "UIInterfaceOrientationPortrait"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "NSCameraUsageDescription": "myne uses the camera to take photos of your hair and inspiration images for your hair journal.",
        "NSPhotoLibraryUsageDescription": "myne needs access to your photo library so you can choose and upload hair inspiration and profile photos.",
        "NSPhotoLibraryAddUsageDescription": "myne saves edited or captured photos to your library when you choose to."
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "screenOrientation": "portrait",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android_adaptive_foreground.png",
        "backgroundColor": "#B2DCC5"
      },
      "versionCode": 1,
      "package": "com.dorica.myne",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#B2DCC5",
          "image": "./assets/images/splash.png",
          "resizeMode": "contain",
          "imageWidth": 220
        }
      ],
      "expo-font",
      "expo-secure-store",
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "PORTRAIT"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "myne needs your location to show nearby salons on the map."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#ffffff"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "buildReactNativeFromSource": true,
            "forceStaticLinking": [
              "react-native-maps",
              "react-native-google-maps"
            ]
          },
          "android": {
            "kotlinVersion": "2.0.21"
          }
        }
      ],
      "./plugins/removeEnableBundleCompression",
      "./plugins/withAndroidPortraitOnly"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "extra": {
      "SUPABASE_URL": "${SUPABASE_URL}",
      "SUPABASE_FUNCTION_URL": "${SUPABASE_FUNCTION_URL}",
      "SUPABASE_ANON": "${SUPABASE_ANON}",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "4b757cda-0041-447c-95f9-0b36c1d70c6c"
      }
    },
    "owner": "dorica"
  }
}
