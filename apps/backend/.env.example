# --- Postgres (Prisma) ---------------------------------------------------------
# If you see: "Can't reach database server at db....supabase.co:5432"
#   1) Supabase dashboard → Project → restore project if it is paused (free tier).
#   2) Settings → Database: copy the connection string again (password reset if needed).
#   3) If port 5432 is blocked on your network, use the Session pooler URI (port 6543)
#      from Connect → ORMs → Prisma, and set DIRECT_URL to the direct :5432 URI for migrations.
#
# Direct (5432), works when the project is running and the network allows DB traffic:
# DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@db.[ref].supabase.co:5432/postgres"
#
# Recommended Supabase layout:
#   DATABASE_URL = Session pooler (port 6543) — backend runtime
#   DIRECT_URL   = Direct DB (port 5432) — required for `prisma migrate deploy` (migrate on pooler often hangs)
#
# Use connection_limit=1 with Prisma + Supabase pooler (recommended in Prisma docs).
# DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL="postgresql://postgres.[ref]:[PASSWORD]@db.[ref].supabase.co:5432/postgres"

DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"
DIRECT_URL="postgresql://user:password@host:5432/database?schema=public"

SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_JWT_SECRET="your-jwt-secret"
PORT=3001

# Optional: Slack incoming webhook for new in-app feedback (Settings → Integrations → Incoming Webhooks).
# SLACK_FEEDBACK_WEBHOOK_URL="https://hooks.slack.com/services/..."
# Optional: bot + channel for feedback messages with status dropdown (incoming webhooks cannot use menus).
# SLACK_FEEDBACK_CHANNEL_ID="C0123456789"
# Optional separate channel for vote activity (omit to skip vote pings).
# SLACK_FEEDBACK_VOTES_WEBHOOK_URL="https://hooks.slack.com/services/..."
# Optional: Slack incoming webhook for user reports (Safety & privacy → Report).
# SLACK_REPORTS_WEBHOOK_URL="https://hooks.slack.com/services/..."
# Optional: bot + channel for report messages with action buttons (incoming webhooks cannot use buttons).
# SLACK_BOT_TOKEN="xoxb-..."
# SLACK_REPORTS_CHANNEL_ID="C0123456789"
# Optional: Slack app signing secret — required for report action buttons.
# Set Interactivity URL in Slack app settings to: https://YOUR-API.onrender.com/api/slack/interactions
# SLACK_SIGNING_SECRET="your-slack-signing-secret"

# --- Billing (optional QA) -------------------------------------------------------
# BILLING_FREE_VISIT_LIMIT=10
# BILLING_DEV_BYPASS=true
# Treat specific professional profile UUIDs as subscribed (star badge on map/profile, unlimited visits):
# BILLING_TEST_SUBSCRIBED_PROFILE_IDS="00000000-0000-4000-8000-000000000001"
