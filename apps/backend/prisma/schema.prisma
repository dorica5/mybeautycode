
// Use @@map for table names; use @map for column names where needed for DB conventions

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum ClientProfessionalLinkStatus {
  pending
  active
  archived
  blocked
  @@map("client_professional_link_status")
}

enum ServiceRecordStatus {
  draft
  completed
  cancelled
  @@map("service_record_status")
}

enum NotificationType {
  link_request
  link_accepted
  link_declined
  shared_inspiration
  service_record
  system
  support
  other
  @@map("notification_type")
}

enum AuditAction {
  create
  update
  delete
  share
  link
  unlink
  status_change
  @@map("audit_action")
}

enum AuditActorType {
  user
  admin
  system
  @@map("audit_actor_type")
}

enum SupportTicketStatus {
  open
  in_progress
  resolved
  closed
  @@map("support_ticket_status")
}

enum SupportTicketPriority {
  low
  medium
  high
  urgent
  @@map("support_ticket_priority")
}

// =============================================================================
// CORE USER / IDENTITY
// =============================================================================

/// Base user identity - only account and display data
model Profile {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime? @map("updated_at") @db.Timestamptz
  email         String?   @db.Text
  firstName     String?   @map("first_name") @db.Text
  lastName      String?   @map("last_name") @db.Text
  /// Lowercase [a-z][a-z0-9_]{2,29}; unique when set (see profileService).
  username      String?   @unique @map("username") @db.Text
  country       String?   @map("country") @db.Text
  avatarUrl    String?   @map("avatar_url") @db.Text
  phoneNumber  String?   @unique @map("phone_number") @db.Text
  setupStatus  Boolean?  @default(false) @map("setup_status")
  signupDate   DateTime? @map("signup_date") @db.Timestamptz

  // Relations
  professionalProfile         ProfessionalProfile?
  clientProfessionalLinksAsClient    ClientProfessionalLink[] @relation("ClientLinks")
  clientProfessionalLinksCreated     ClientProfessionalLink[] @relation("ClientLinkCreatedBy")
  clientProfessionProfiles    ClientProfessionProfile[]
  serviceRecordsAsClient      ServiceRecord[] @relation("ServiceRecordClient")
  serviceRecordsAsCreator     ServiceRecord[] @relation("ServiceRecordCreator")
  inspirations                Inspiration[]
  sharedInspirationsSent      SharedInspiration[] @relation("SharedInspirationSender")
  sharedInspirationsReceived  SharedInspiration[] @relation("SharedInspirationRecipient")
  notifications               Notification[] @relation("NotificationRecipient")
  notificationsSent           Notification[] @relation("NotificationSender")
  blockedUsersAsBlocker       BlockedUser[] @relation("BlockedUserBlocker")
  blockedUsersAsBlocked       BlockedUser[] @relation("BlockedUserBlocked")
  userStrike                  UserStrike?
  reportedUsersAsReporter     ReportedUser[] @relation("ReportedUserReporter")
  reportedUsersAsReported     ReportedUser[] @relation("ReportedUserReported")
  userRestrictions            UserRestriction[]
  userRestrictionsApplied     UserRestriction[] @relation("UserRestrictionApplier")
  adminActionsAsAdmin         AdminAction[] @relation("AdminActionAdmin")
  adminActionsAsTarget        AdminAction[] @relation("AdminActionTarget")
  supportTickets               SupportTicket[]
  pushTokens                  PushToken[]
  auditLogsAsActor            AuditLog[] @relation("AuditLogActor")
  adminUser                   AdminUser?
  clientProfessionProfilesAsUpdater ClientProfessionProfile[] @relation("ClientProfessionProfileUpdater")
  serviceRecordMediaAsUploader ServiceRecordMedia[] @relation("ServiceRecordMediaUploader")

  @@map("profiles")
}

// =============================================================================
// PROFESSIONALS
// =============================================================================

/// Professional/business-facing info. 1:1 with profiles.
model ProfessionalProfile {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profileId        String   @unique @map("profile_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime? @map("updated_at") @db.Timestamptz
  displayName      String?  @map("display_name") @db.Text
  businessName    String?  @map("business_name") @db.Text
  businessNumber  String?  @map("business_number") @db.Text
  aboutMe          String?  @map("about_me") @db.Text
  socialMedia      String?  @map("social_media") @db.Text
  bookingSite      String?  @map("booking_site") @db.Text

  profile           Profile           @relation(fields: [profileId], references: [id], onDelete: Cascade)
  professionalProfessions ProfessionalProfession[]
  clientProfessionalLinks ClientProfessionalLink[]
  serviceRecords    ServiceRecord[]

  @@map("professional_profiles")
}

/// Lookup table: hair, brows, lashes, nails, esthetician, etc.
model Profession {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  code        String   @unique @db.Text // e.g. "hair", "brows", "nails"
  sortOrder   Int      @default(0) @map("sort_order")

  professionalProfessions ProfessionalProfession[]
  clientProfessionProfiles ClientProfessionProfile[]
  serviceRecords           ServiceRecord[]
  inspirations             Inspiration[]
  sharedInspirations       SharedInspiration[]

  @@map("professions")
}

/// Join: professional can have multiple professions. 
model ProfessionalProfession {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  professionalProfileId String   @map("professional_profile_id") @db.Uuid
  professionId          String   @map("profession_id") @db.Uuid
  isActive               Boolean?  @default(true) @map("is_active")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime? @map("updated_at") @db.Timestamptz

  professionalProfile ProfessionalProfile @relation(fields: [professionalProfileId], references: [id], onDelete: Cascade)
  profession          Profession          @relation(fields: [professionId], references: [id], onDelete: Cascade)

  @@unique([professionalProfileId, professionId])
  @@map("professional_professions")
}

// =============================================================================
// CLIENT <-> PROFESSIONAL RELATIONSHIP
// =============================================================================

/// Links a client (user) to a professional. Status, created_by, timestamps for audit.
model ClientProfessionalLink {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientUserId          String   @map("client_user_id") @db.Uuid
  professionalProfileId String   @map("professional_profile_id") @db.Uuid
  status                ClientProfessionalLinkStatus @default(pending)
  createdByUserId       String?  @map("created_by_user_id") @db.Uuid
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime? @map("updated_at") @db.Timestamptz
  statusChangedAt       DateTime? @map("status_changed_at") @db.Timestamptz

  clientUser           Profile           @relation("ClientLinks", fields: [clientUserId], references: [id], onDelete: Cascade)
  professionalProfile  ProfessionalProfile @relation(fields: [professionalProfileId], references: [id], onDelete: Cascade)
  createdByUser        Profile?          @relation("ClientLinkCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  serviceRecords       ServiceRecord[]

  @@unique([clientUserId, professionalProfileId])
  @@index([clientUserId])
  @@index([professionalProfileId])
  @@index([status])
  @@map("client_professional_links")
}

// =============================================================================
// CLIENT BEAUTY BASELINE DATA
// =============================================================================

/// Generalized baseline per client + profession. baseline_data is Json for profession-specific attributes.
model ClientProfessionProfile {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientUserId            String   @map("client_user_id") @db.Uuid
  professionId            String   @map("profession_id") @db.Uuid
  baselineData            Json?    @map("baseline_data") // e.g. { hairThickness, hairStructure, browShape, ... }
  lastUpdatedByUserId     String?  @map("last_updated_by_user_id") @db.Uuid
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime? @map("updated_at") @db.Timestamptz

  clientUser         Profile           @relation(fields: [clientUserId], references: [id], onDelete: Cascade)
  profession         Profession        @relation(fields: [professionId], references: [id], onDelete: Cascade)
  lastUpdatedByUser Profile?           @relation("ClientProfessionProfileUpdater", fields: [lastUpdatedByUserId], references: [id], onDelete: SetNull)

  @@unique([clientUserId, professionId])
  @@index([clientUserId])
  @@index([professionId])
  @@map("client_profession_profiles")
}

// =============================================================================
// SERVICE HISTORY
// =============================================================================

/// Generalized service event/visit record. record_data holds profession-specific visit details.
model ServiceRecord {
  id                         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientUserId               String   @map("client_user_id") @db.Uuid
  professionalProfileId      String   @map("professional_profile_id") @db.Uuid
  professionId               String   @map("profession_id") @db.Uuid
  clientProfessionalLinkId   String?  @map("client_professional_link_id") @db.Uuid
  serviceName                String?  @map("service_name") @db.Text
  summary                    String?  @db.Text
  price                      Decimal? @db.Decimal(10, 2)
  durationMinutes            Int?     @map("duration_minutes")
  recordStatus               ServiceRecordStatus @default(completed) @map("record_status")
  recordData                 Json?    @map("record_data") // profession-specific visit details
  createdByUserId            String?  @map("created_by_user_id") @db.Uuid
  createdAt                  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                  DateTime? @map("updated_at") @db.Timestamptz

  clientUser              Profile                 @relation("ServiceRecordClient", fields: [clientUserId], references: [id], onDelete: Cascade)
  professionalProfile     ProfessionalProfile     @relation(fields: [professionalProfileId], references: [id], onDelete: Cascade)
  profession              Profession              @relation(fields: [professionId], references: [id], onDelete: Cascade)
  clientProfessionalLink  ClientProfessionalLink? @relation(fields: [clientProfessionalLinkId], references: [id], onDelete: SetNull)
  createdByUser           Profile?                @relation("ServiceRecordCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  media                   ServiceRecordMedia[]

  @@index([clientUserId])
  @@index([professionalProfileId])
  @@index([professionId])
  @@index([createdAt])
  @@map("service_records")
}

/// Media attached to service records.
model ServiceRecordMedia {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceRecordId   String   @map("service_record_id") @db.Uuid
  mediaType         String   @map("media_type") @db.Text // image, video
  mediaUrl          String   @map("media_url") @db.Text
  mediaTag          String?  @map("media_tag") @db.Text // optional category/tag
  sortOrder         Int?     @map("sort_order")
  uploadedByUserId  String?  @map("uploaded_by_user_id") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  serviceRecord  ServiceRecord @relation(fields: [serviceRecordId], references: [id], onDelete: Cascade)
  uploadedByUser Profile?      @relation("ServiceRecordMediaUploader", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([serviceRecordId])
  @@map("service_record_media")
}

// =============================================================================
// INSPIRATION SYSTEM
// =============================================================================

/// Inspiration owned by a user, tied to a profession.
model Inspiration {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId          String   @map("owner_id") @db.Uuid
  professionId     String   @map("profession_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime? @map("updated_at") @db.Timestamptz
  imageUrl         String?  @map("image_url") @db.Text
  lowResImageUrl   String?  @map("low_res_image_url") @db.Text
  lowMiddleResUrl  String?  @map("low_middle_res_url") @db.Text
  highMiddleResUrl String?  @map("high_middle_res_url") @db.Text

  owner           Profile            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  profession      Profession         @relation(fields: [professionId], references: [id], onDelete: Cascade)
  sharedInspirations SharedInspiration[]

  @@index([ownerId])
  @@index([professionId])
  @@map("inspirations")
}

/// Shared inspiration between users.
model SharedInspiration {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  senderUserId   String   @map("sender_user_id") @db.Uuid
  recipientUserId String  @map("recipient_user_id") @db.Uuid
  professionId   String   @map("profession_id") @db.Uuid
  inspirationId  String?  @map("inspiration_id") @db.Uuid
  imageUrl       String?  @map("image_url") @db.Text
  batchId        String?  @map("batch_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  sender         Profile    @relation("SharedInspirationSender", fields: [senderUserId], references: [id], onDelete: Cascade)
  recipient      Profile    @relation("SharedInspirationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  profession     Profession @relation(fields: [professionId], references: [id], onDelete: Cascade)
  inspiration    Inspiration? @relation(fields: [inspirationId], references: [id], onDelete: SetNull)

  @@index([senderUserId])
  @@index([recipientUserId])
  @@index([batchId])
  @@map("shared_inspirations")
}

// =============================================================================
// NOTIFICATIONS
// =============================================================================

model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  message   String   @db.Text
  read      Boolean  @default(false)
  type      NotificationType?
  senderId  String?  @map("sender_id") @db.Uuid
  status    String?  @db.Text
  data      Json?    // flexible payload instead of plain text extraData
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user   Profile  @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  sender Profile? @relation("NotificationSender", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([read])
  @@map("notifications")
}

// =============================================================================
// MODERATION / SAFETY / SUPPORT
// =============================================================================

model BlockedUser {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  blockerId String   @map("blocker_id") @db.Uuid
  blockedId String   @map("blocked_id") @db.Uuid
  reason    String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  blocker Profile @relation("BlockedUserBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked Profile @relation("BlockedUserBlocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("blocked_users")
}

model UserStrike {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String    @unique @map("user_id") @db.Uuid
  strikeCount    Int       @default(0) @map("strike_count")
  isBanned       Boolean   @default(false) @map("is_banned")
  isRestricted   Boolean   @default(false) @map("is_restricted")
  banReason      String?   @map("ban_reason") @db.Text
  banDate        DateTime? @map("ban_date") @db.Timestamptz
  bannedBy       String?   @map("banned_by") @db.Uuid
  lastStrikeDate DateTime? @map("last_strike_date") @db.Timestamptz
  adminNotes     String?   @map("admin_notes") @db.Text
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime? @map("updated_at") @db.Timestamptz

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_strikes")
}

model ReportedUser {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reporterId String   @map("reporter_id") @db.Uuid
  reportedId String   @map("reported_id") @db.Uuid
  reason     String   @db.Text
  status     String   @default("pending") @db.Text
  priority   String?  @db.Text
  adminNotes String?  @map("admin_notes") @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime? @map("updated_at") @db.Timestamptz

  reporter Profile @relation("ReportedUserReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reported Profile @relation("ReportedUserReported", fields: [reportedId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([reportedId])
  @@index([status])
  @@map("reported_users")
}

model UserRestriction {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  restrictedUntil DateTime @map("restricted_until") @db.Timestamptz
  reason          String   @db.Text
  appliedBy       String   @map("applied_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  user    Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  appliedByProfile Profile @relation("UserRestrictionApplier", fields: [appliedBy], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_restrictions")
}

model AdminAction {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminId      String   @map("admin_id") @db.Uuid
  targetUserId String   @map("target_user_id") @db.Uuid
  actionType   String   @map("action_type") @db.Text
  description  String   @db.Text
  notes        String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  admin  Profile @relation("AdminActionAdmin", fields: [adminId], references: [id], onDelete: Cascade)
  target Profile @relation("AdminActionTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([targetUserId])
  @@index([createdAt])
  @@map("admin_actions")
}

model SupportTicket {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  subject   String?  @db.Text
  message   String   @db.Text
  status    SupportTicketStatus @default(open)
  priority  SupportTicketPriority?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime? @map("updated_at") @db.Timestamptz

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("support_tickets")
}

model PushToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  token     String    @db.Text
  deviceId  String?   @map("device_id") @db.Text // optional: support multi-device
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime? @map("updated_at") @db.Timestamptz

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
  @@map("push_tokens")
}

// =============================================================================
// LOGGING / AUDIT
// =============================================================================

/// Audit log for important actions. Supports who, what, when, metadata.
model AuditLog {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId      String?       @map("actor_id") @db.Uuid
  actorType    AuditActorType @default(user) @map("actor_type")
  action       AuditAction
  entityTable  String        @map("entity_table") @db.Text
  entityId     String        @map("entity_id") @db.Uuid
  metadata     Json?         // optional extra context
  oldData      Json?         @map("old_data") // for sensitive tracked changes
  newData      Json?         @map("new_data")
  ipAddress    String?       @map("ip_address") @db.Text
  userAgent    String?       @map("user_agent") @db.Text
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz

  actor Profile? @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entityTable, entityId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

/// Admin users for RLS. Managed via service_role only. Used by is_admin().
model AdminUser {
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId])
  @@map("admin_users")
}

/// Domain event / activity log for higher-level business events.
model ActivityLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  eventType   String   @map("event_type") @db.Text
  entityType  String?  @map("entity_type") @db.Text
  entityId    String?  @map("entity_id") @db.Uuid
  payload     Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@map("activity_logs")
}
