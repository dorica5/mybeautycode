generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Base user identity - only account and display data
model Profile {
  id                                String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt                         DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                         DateTime?                 @map("updated_at") @db.Timestamptz(6)
  email                             String?
  avatarUrl                         String?                   @map("avatar_url")
  phoneNumber                       String?                   @unique @map("phone_number")
  setupStatus                       Boolean?                  @default(false) @map("setup_status")
  signupDate                        DateTime?                 @map("signup_date") @db.Timestamptz(6)
  firstName                         String?                   @map("first_name")
  lastName                          String?                   @map("last_name")
  country                           String?                   @map("country")
  /// Lowercase [a-z][a-z0-9_]{2,29}; unique when set (see profileService).
  username                          String?                   @unique @map("username")
  adminActionsAsAdmin               AdminAction[]             @relation("AdminActionAdmin")
  adminActionsAsTarget              AdminAction[]             @relation("AdminActionTarget")
  adminUser                         AdminUser?
  auditLogsAsActor                  AuditLog[]                @relation("AuditLogActor")
  blockedUsersAsBlocked             BlockedUser[]             @relation("BlockedUserBlocked")
  blockedUsersAsBlocker             BlockedUser[]             @relation("BlockedUserBlocker")
  clientProfessionProfiles          ClientProfessionProfile[]
  clientProfessionProfilesAsUpdater ClientProfessionProfile[] @relation("ClientProfessionProfileUpdater")
  clientProfessionalLinksAsClient   ClientProfessionalLink[]  @relation("ClientLinks")
  clientProfessionalLinksCreated    ClientProfessionalLink[]  @relation("ClientLinkCreatedBy")
  inspirations                      Inspiration[]
  notificationsSent                 Notification[]            @relation("NotificationSender")
  notifications                     Notification[]            @relation("NotificationRecipient")
  professionalProfile               ProfessionalProfile?
  publicProfileWorkImages           PublicProfileWorkImage[]
  pushTokens                        PushToken[]
  reportedUsersAsReported           ReportedUser[]            @relation("ReportedUserReported")
  reportedUsersAsReporter           ReportedUser[]            @relation("ReportedUserReporter")
  serviceRecordMediaAsUploader      ServiceRecordMedia[]      @relation("ServiceRecordMediaUploader")
  serviceRecordsAsClient            ServiceRecord[]           @relation("ServiceRecordClient")
  serviceRecordsAsCreator           ServiceRecord[]           @relation("ServiceRecordCreator")
  sharedInspirationsReceived        SharedInspiration[]       @relation("SharedInspirationRecipient")
  sharedInspirationsSent            SharedInspiration[]       @relation("SharedInspirationSender")
  supportTickets                    SupportTicket[]
  userRestrictionsApplied           UserRestriction[]         @relation("UserRestrictionApplier")
  userRestrictions                  UserRestriction[]
  userStrike                        UserStrike?

  @@map("profiles")
}

/// Professional/business-facing info. 1:1 with profiles.
model ProfessionalProfile {
  id                       String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profileId                String                    @unique @map("profile_id") @db.Uuid
  createdAt                DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime?                 @map("updated_at") @db.Timestamptz(6)
  displayName              String?                   @map("display_name")
  clientProfessionalLinks  ClientProfessionalLink[]
  professionalHairProfile  ProfessionalHairProfile?
  professionalNailsProfile ProfessionalNailsProfile?
  professionalProfessions  ProfessionalProfession[]
  profile                  Profile                   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  serviceRecords           ServiceRecord[]

  @@map("professional_profiles")
}

/// Hairdresser-specific profile data (visible to other pros, not to clients).
model ProfessionalHairProfile {
  id                    String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  professionalProfileId String              @unique @map("professional_profile_id") @db.Uuid
  colorBrand            String?             @map("color_brand")
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime?           @map("updated_at") @db.Timestamptz(6)
  professionalProfile   ProfessionalProfile @relation(fields: [professionalProfileId], references: [id], onDelete: Cascade)

  @@map("professional_hair_profiles")
}

/// Nail tech–specific profile data (future columns). Same pattern as hair child table.
model ProfessionalNailsProfile {
  id                    String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  professionalProfileId String              @unique @map("professional_profile_id") @db.Uuid
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime?           @map("updated_at") @db.Timestamptz(6)
  professionalProfile   ProfessionalProfile @relation(fields: [professionalProfileId], references: [id], onDelete: Cascade)

  @@map("professional_nails_profiles")
}

/// Lookup table: hair, brows_lashes, nails, esthetician, etc.
model Profession {
  id                       String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt                DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  code                     String                    @unique
  sortOrder                Int                       @default(0) @map("sort_order")
  clientProfessionProfiles ClientProfessionProfile[]
  clientProfessionalLinks  ClientProfessionalLink[]
  inspirations             Inspiration[]
  professionalProfessions  ProfessionalProfession[]
  serviceRecords           ServiceRecord[]
  sharedInspirations       SharedInspiration[]

  @@map("professions")
}

/// Join: professional can have multiple professions. 
model ProfessionalProfession {
  id                    String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  professionalProfileId String              @map("professional_profile_id") @db.Uuid
  professionId          String              @map("profession_id") @db.Uuid
  isActive              Boolean?            @default(true) @map("is_active")
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime?           @map("updated_at") @db.Timestamptz(6)
  /// Salon / business name for this profession (e.g. different venues per role).
  businessName          String?             @map("business_name")
  businessNumber        String?             @map("business_number")
  businessAddress       String?             @map("business_address")
  aboutMe               String?             @map("about_me")
  socialMedia           String?             @map("social_media")
  bookingSite           String?             @map("booking_site")
  /// FK to the canonical Salon (grouped by Google place_id). Null for legacy free-text addresses.
  salonId               String?             @map("salon_id") @db.Uuid
  profession            Profession          @relation(fields: [professionId], references: [id], onDelete: Cascade)
  professionalProfile   ProfessionalProfile @relation(fields: [professionalProfileId], references: [id], onDelete: Cascade)
  salon                 Salon?              @relation(fields: [salonId], references: [id], onDelete: SetNull)

  @@unique([professionalProfileId, professionId])
  @@index([salonId])
  @@map("professional_professions")
}

/// A physical place (identified by Google place_id) that ≥1 professional has set as their business address.
/// Pros sharing the same place_id belong to the same salon pin on the map.
model Salon {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  googlePlaceId           String                   @unique @map("google_place_id")
  /// Best-effort label (first non-null businessName from a pro at this address). Nullable.
  name                    String?
  formattedAddress        String                   @map("formatted_address")
  latitude                Float
  longitude               Float
  createdAt               DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime?                @map("updated_at") @db.Timestamptz(6)
  professionalProfessions ProfessionalProfession[]

  @@index([latitude, longitude])
  @@map("salons")
}

/// Links a client (user) to a professional **per profession lane** (brow vs nail are separate “accounts”).
model ClientProfessionalLink {
  id                    String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientUserId          String                       @map("client_user_id") @db.Uuid
  professionalProfileId String                       @map("professional_profile_id") @db.Uuid
  status                ClientProfessionalLinkStatus @default(pending)
  createdByUserId       String?                      @map("created_by_user_id") @db.Uuid
  createdAt             DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime?                    @map("updated_at") @db.Timestamptz(6)
  statusChangedAt       DateTime?                    @map("status_changed_at") @db.Timestamptz(6)
  professionId          String                       @map("profession_id") @db.Uuid
  clientUser            Profile                      @relation("ClientLinks", fields: [clientUserId], references: [id], onDelete: Cascade)
  createdByUser         Profile?                     @relation("ClientLinkCreatedBy", fields: [createdByUserId], references: [id])
  profession            Profession                   @relation(fields: [professionId], references: [id], onDelete: Cascade)
  professionalProfile   ProfessionalProfile          @relation(fields: [professionalProfileId], references: [id], onDelete: Cascade)
  serviceRecords        ServiceRecord[]

  @@unique([clientUserId, professionalProfileId, professionId], map: "client_professional_links_client_user_id_professional_profile_i")
  @@index([clientUserId])
  @@index([professionalProfileId])
  @@index([status])
  @@map("client_professional_links")
}

/// Generalized baseline per client + profession. baseline_data is Json for profession-specific attributes.
model ClientProfessionProfile {
  id                  String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientUserId        String     @map("client_user_id") @db.Uuid
  professionId        String     @map("profession_id") @db.Uuid
  baselineData        Json?      @map("baseline_data")
  lastUpdatedByUserId String?    @map("last_updated_by_user_id") @db.Uuid
  createdAt           DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime?  @map("updated_at") @db.Timestamptz(6)
  clientUser          Profile    @relation(fields: [clientUserId], references: [id], onDelete: Cascade)
  lastUpdatedByUser   Profile?   @relation("ClientProfessionProfileUpdater", fields: [lastUpdatedByUserId], references: [id])
  profession          Profession @relation(fields: [professionId], references: [id], onDelete: Cascade)

  @@unique([clientUserId, professionId])
  @@index([clientUserId])
  @@index([professionId])
  @@map("client_profession_profiles")
}

/// Generalized service event/visit record. record_data holds profession-specific visit details.
model ServiceRecord {
  id                       String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientUserId             String                  @map("client_user_id") @db.Uuid
  /// Nullable so deleting the professional preserves the client's visit history.
  professionalProfileId    String?                 @map("professional_profile_id") @db.Uuid
  professionId             String                  @map("profession_id") @db.Uuid
  clientProfessionalLinkId String?                 @map("client_professional_link_id") @db.Uuid
  serviceName              String?                 @map("service_name")
  summary                  String?
  price                    Decimal?                @db.Decimal(10, 2)
  durationMinutes          Int?                    @map("duration_minutes")
  recordStatus             ServiceRecordStatus     @default(completed) @map("record_status")
  recordData               Json?                   @map("record_data")
  createdByUserId          String?                 @map("created_by_user_id") @db.Uuid
  createdAt                DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime?               @map("updated_at") @db.Timestamptz(6)
  media                    ServiceRecordMedia[]
  clientProfessionalLink   ClientProfessionalLink? @relation(fields: [clientProfessionalLinkId], references: [id], onDelete: SetNull)
  clientUser               Profile                 @relation("ServiceRecordClient", fields: [clientUserId], references: [id], onDelete: Cascade)
  createdByUser            Profile?                @relation("ServiceRecordCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  profession               Profession              @relation(fields: [professionId], references: [id], onDelete: Cascade)
  professionalProfile      ProfessionalProfile?    @relation(fields: [professionalProfileId], references: [id], onDelete: SetNull)

  @@index([clientUserId])
  @@index([professionalProfileId])
  @@index([professionId])
  @@index([createdAt])
  @@map("service_records")
}

/// Media attached to service records.
model ServiceRecordMedia {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceRecordId  String        @map("service_record_id") @db.Uuid
  mediaType        String        @map("media_type")
  mediaUrl         String        @map("media_url")
  mediaTag         String?       @map("media_tag")
  sortOrder        Int?          @map("sort_order")
  uploadedByUserId String?       @map("uploaded_by_user_id") @db.Uuid
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  serviceRecord    ServiceRecord @relation(fields: [serviceRecordId], references: [id], onDelete: Cascade)
  uploadedByUser   Profile?      @relation("ServiceRecordMediaUploader", fields: [uploadedByUserId], references: [id])

  @@index([serviceRecordId])
  @@map("service_record_media")
}

/// Inspiration owned by a user, tied to a profession.
model Inspiration {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId            String              @map("owner_id") @db.Uuid
  professionId       String              @map("profession_id") @db.Uuid
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime?           @map("updated_at") @db.Timestamptz(6)
  imageUrl           String?             @map("image_url")
  lowResImageUrl     String?             @map("low_res_image_url")
  lowMiddleResUrl    String?             @map("low_middle_res_url")
  highMiddleResUrl   String?             @map("high_middle_res_url")
  owner              Profile             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  profession         Profession          @relation(fields: [professionId], references: [id], onDelete: Cascade)
  sharedInspirations SharedInspiration[]

  @@index([ownerId])
  @@index([professionId])
  @@map("inspirations")
}

/// Public portfolio on Get discovered / pro profile. Not visit (service-record) images.
model PublicProfileWorkImage {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId        String   @map("owner_id") @db.Uuid
  professionCode String   @map("profession_code")
  imageUrl       String   @map("image_url")
  lowResImageUrl String?  @map("low_res_image_url")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  owner          Profile  @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, professionCode])
  @@map("public_profile_work_images")
}

/// Shared inspiration between users.
model SharedInspiration {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  senderUserId    String       @map("sender_user_id") @db.Uuid
  recipientUserId String       @map("recipient_user_id") @db.Uuid
  professionId    String       @map("profession_id") @db.Uuid
  inspirationId   String?      @map("inspiration_id") @db.Uuid
  imageUrl        String?      @map("image_url")
  batchId         String?      @map("batch_id") @db.Uuid
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  inspiration     Inspiration? @relation(fields: [inspirationId], references: [id])
  profession      Profession   @relation(fields: [professionId], references: [id], onDelete: Cascade)
  recipient       Profile      @relation("SharedInspirationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  sender          Profile      @relation("SharedInspirationSender", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([senderUserId])
  @@index([recipientUserId])
  @@index([batchId])
  @@map("shared_inspirations")
}

model Notification {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String            @map("user_id") @db.Uuid
  message        String
  read           Boolean           @default(false)
  type           NotificationType?
  senderId       String?           @map("sender_id") @db.Uuid
  status         String?
  data           Json?
  /// Inbox scope: NULL = client inbox, "hair" / "nails" / "brows" = that
  /// profession account's inbox. Pros with multiple profession accounts only
  /// see a notification in the lane it was sent to.
  professionCode String?           @map("profession_code")
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  sender         Profile?          @relation("NotificationSender", fields: [senderId], references: [id])
  user           Profile           @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([userId, professionCode])
  @@map("notifications")
}

model BlockedUser {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  blockerId String   @map("blocker_id") @db.Uuid
  blockedId String   @map("blocked_id") @db.Uuid
  reason    String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  blocked   Profile  @relation("BlockedUserBlocked", fields: [blockedId], references: [id], onDelete: Cascade)
  blocker   Profile  @relation("BlockedUserBlocker", fields: [blockerId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("blocked_users")
}

model UserStrike {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String    @unique @map("user_id") @db.Uuid
  strikeCount    Int       @default(0) @map("strike_count")
  isBanned       Boolean   @default(false) @map("is_banned")
  isRestricted   Boolean   @default(false) @map("is_restricted")
  banReason      String?   @map("ban_reason")
  banDate        DateTime? @map("ban_date") @db.Timestamptz(6)
  bannedBy       String?   @map("banned_by") @db.Uuid
  lastStrikeDate DateTime? @map("last_strike_date") @db.Timestamptz(6)
  adminNotes     String?   @map("admin_notes")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime? @map("updated_at") @db.Timestamptz(6)
  user           Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_strikes")
}

model ReportedUser {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reporterId String    @map("reporter_id") @db.Uuid
  reportedId String    @map("reported_id") @db.Uuid
  reason     String
  status     String    @default("pending")
  priority   String?
  adminNotes String?   @map("admin_notes")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime? @map("updated_at") @db.Timestamptz(6)
  reported   Profile   @relation("ReportedUserReported", fields: [reportedId], references: [id], onDelete: Cascade)
  reporter   Profile   @relation("ReportedUserReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([reportedId])
  @@index([status])
  @@map("reported_users")
}

model UserRestriction {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  restrictedUntil  DateTime @map("restricted_until") @db.Timestamptz(6)
  reason           String
  appliedBy        String   @map("applied_by") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  appliedByProfile Profile  @relation("UserRestrictionApplier", fields: [appliedBy], references: [id], onDelete: Cascade)
  user             Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_restrictions")
}

model AdminAction {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminId      String   @map("admin_id") @db.Uuid
  targetUserId String   @map("target_user_id") @db.Uuid
  actionType   String   @map("action_type")
  description  String
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  admin        Profile  @relation("AdminActionAdmin", fields: [adminId], references: [id], onDelete: Cascade)
  target       Profile  @relation("AdminActionTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([targetUserId])
  @@index([createdAt])
  @@map("admin_actions")
}

model SupportTicket {
  id        String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String                 @map("user_id") @db.Uuid
  subject   String?
  message   String
  status    SupportTicketStatus    @default(open)
  priority  SupportTicketPriority?
  createdAt DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime?              @map("updated_at") @db.Timestamptz(6)
  user      Profile                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("support_tickets")
}

model PushToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  token     String
  deviceId  String?   @map("device_id")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime? @map("updated_at") @db.Timestamptz(6)
  user      Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
  @@map("push_tokens")
}

/// Audit log for important actions. Supports who, what, when, metadata.
model AuditLog {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId     String?        @map("actor_id") @db.Uuid
  actorType   AuditActorType @default(user) @map("actor_type")
  action      AuditAction
  entityTable String         @map("entity_table")
  entityId    String         @map("entity_id") @db.Uuid
  metadata    Json?
  oldData     Json?          @map("old_data")
  newData     Json?          @map("new_data")
  ipAddress   String?        @map("ip_address")
  userAgent   String?        @map("user_agent")
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  actor       Profile?       @relation("AuditLogActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entityTable, entityId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

/// Admin users for RLS. Managed via service_role only. Used by is_admin().
model AdminUser {
  userId    String   @id @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_users")
}

/// Domain event / activity log for higher-level business events.
model ActivityLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  eventType  String   @map("event_type")
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id") @db.Uuid
  payload    Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@map("activity_logs")
}

enum ClientProfessionalLinkStatus {
  pending
  active
  archived
  blocked

  @@map("client_professional_link_status")
}

enum ServiceRecordStatus {
  draft
  completed
  cancelled

  @@map("service_record_status")
}

enum NotificationType {
  link_request
  link_accepted
  link_declined
  shared_inspiration
  service_record
  system
  support
  other

  @@map("notification_type")
}

enum AuditAction {
  create
  update
  delete
  share
  link
  unlink
  status_change

  @@map("audit_action")
}

enum AuditActorType {
  user
  admin
  system

  @@map("audit_actor_type")
}

enum SupportTicketStatus {
  open
  in_progress
  resolved
  closed

  @@map("support_ticket_status")
}

enum SupportTicketPriority {
  low
  medium
  high
  urgent

  @@map("support_ticket_priority")
}
